# Reclaim Era campaign backend — environment variables
# Copy this file to .env and fill in real values. NEVER commit .env.

# From https://dashboard.razorpay.com -> Account & Settings -> API Keys
# Use rzp_test_... keys while testing, rzp_live_... after KYC approval.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Neon (https://neon.tech) connection string:
# Dashboard -> your project -> Connect -> copy the "Connection string"
# It looks like: postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# The origin your website is served from, e.g. https://reclaimera.in
# (use * only during local development)
ALLOWED_ORIGIN=*

# Port for local development
PORT=5001
